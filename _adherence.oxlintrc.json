{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/navigation/**",
              "components/weather/**",
              "explorations/timelines-v2/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomNavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<BottomNavItem> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|icon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConfidenceTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|showPct|style|key|ref|className|style|children)$/]",
        "message": "<ConfidenceTag> doesn't accept that prop. Declared props: value, showPct, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DayTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:dow|hi|lo|rain|values|selected|today|past|onClick|style|key|ref|className|style|children)$/]",
        "message": "<DayTile> doesn't accept that prop. Declared props: dow, hi, lo, rain, values, selected, today, past, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DrawerItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|onClick|key|ref|className|style|children)$/]",
        "message": "<DrawerItem> doesn't accept that prop. Declared props: label, icon, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|shape|size|bordered|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: label, shape, size, bordered, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:square|round)$/]",
        "message": "<IconButton> shape must be one of 'square' | 'round'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|wordmark|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: size, wordmark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:metric|title|value|subs|confidence|glass|style|key|ref|className|style|children)$/]",
        "message": "<MetricCard> doesn't accept that prop. Declared props: metric, title, value, subs, confidence, glass, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute[name.name='metric'] > Literal[value!=/^(?:temp|rain|wind|cloud)$/]",
        "message": "<MetricCard> metric must be one of 'temp' | 'rain' | 'wind' | 'cloud'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:metric|size|color|style|key|ref|className|style|children)$/]",
        "message": "<MetricIcon> doesn't accept that prop. Declared props: metric, size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricIcon'] > JSXAttribute[name.name='metric'] > Literal[value!=/^(?:temp|rain|wind|cloud)$/]",
        "message": "<MetricIcon> metric must be one of 'temp' | 'rain' | 'wind' | 'cloud'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|subtitle|children|onClose|maxWidth|footer|style|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: open, title, subtitle, children, onClose, maxWidth, footer, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelDef'] > JSXAttribute > JSXIdentifier[name!=/^(?:short|color|label|desc|key|ref|className|style|children)$/]",
        "message": "<ModelDef> doesn't accept that prop. Declared props: short, color, label, desc."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelToggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:model|enabled|unavailable|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ModelToggle> doesn't accept that prop. Declared props: model, enabled, unavailable, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SparklineTick'] > JSXAttribute > JSXIdentifier[name!=/^(?:frac|kind|key|ref|className|style|children)$/]",
        "message": "<SparklineTick> doesn't accept that prop. Declared props: frac, kind."
      },
      {
        "selector": "JSXOpeningElement[name.name='SparklineTick'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:rise|set)$/]",
        "message": "<SparklineTick> kind must be one of 'rise' | 'set'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|enabled|color|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: icon, label, enabled, color, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WeatherIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:code|night|size|style|key|ref|className|style|children)$/]",
        "message": "<WeatherIcon> doesn't accept that prop. Declared props: code, night, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WeatherOrbRanges'] > JSXAttribute > JSXIdentifier[name!=/^(?:tempMin|tempMax|windMax|rainMax|key|ref|className|style|children)$/]",
        "message": "<WeatherOrbRanges> doesn't accept that prop. Declared props: tempMin, tempMax, windMax, rainMax."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
